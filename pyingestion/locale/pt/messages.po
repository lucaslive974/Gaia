msgid "cli_desc"
msgstr "PyIngestion (Codinome: Gaia) - Ferramenta CLI de extração geral de dados de documentos para CSV."

msgid "cli_input_dir_help"
msgstr "Caminho do diretório contendo os arquivos PDF a serem processados."

msgid "cli_output_help"
msgstr "Caminho do arquivo CSV de saída (Padrão: {default_csv})."

msgid "cli_resume_help"
msgstr "Retoma o processamento a partir do último arquivo concluído com sucesso."

msgid "cli_recursive_help"
msgstr "Busca arquivos PDF recursivamente nos subdiretórios."

msgid "cli_regex_help"
msgstr "Caminho do arquivo JSON contendo as regras regex customizadas."

msgid "cli_test_help"
msgstr "Testa as regras de regex na primeira página do arquivo PDF fornecido."

msgid "cli_pages_per_unit_help"
msgstr "Número de páginas que compõem uma unidade de texto para o casamento de padrões (Padrão: 1)."

msgid "cli_lang_help"
msgstr "Define o idioma da interface e mensagens (en ou pt) (Padrão: en)."

msgid "err_resume_no_state"
msgstr "Nenhum estado de retomada encontrado no diretório atual. É necessário especificar o 'input_dir'."

msgid "err_input_dir_required"
msgstr "o argumento posicional 'input_dir' é obrigatório a menos que --resume ou --test seja usado."

msgid "err_regex_required_normal"
msgstr "o argumento '--regex' é obrigatório para definir os padrões de extração."

msgid "err_regex_required_resume"
msgstr "o argumento '--regex' é obrigatório para retomar a extração."

msgid "err_ppu_invalid"
msgstr "o argumento '--pages-per-unit' deve ser um número inteiro maior ou igual a 1."

msgid "err_lang_invalid"
msgstr "o argumento '--lang' deve ser 'en' ou 'pt'."

msgid "err_dir_not_exist"
msgstr "O diretório de entrada '{base_path}' não existe."

msgid "err_not_a_dir"
msgstr "O caminho de entrada '{base_path}' não é um diretório."

