msgid "cli_type_help"
msgstr "Set the built-in parser type to use (choices: pdf, docx, ocr) (Default: pdf)."

msgid "err_type_invalid"
msgstr "the '--type' argument must be 'pdf', 'docx', or 'ocr'."

msgid "cli_dump_help"
msgstr "Dump raw extracted text from a file (separated by page/unit blocks) to console."

