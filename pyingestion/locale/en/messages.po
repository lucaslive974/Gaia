msgid "cli_desc"
msgstr "PyIngestion (Codename: Gaia) - General-purpose document to CSV data extraction CLI tool."

msgid "cli_input_dir_help"
msgstr "Path to the directory containing the PDF files to process."

msgid "cli_output_help"
msgstr "Path to the output CSV file (Default: {default_csv})."

msgid "cli_resume_help"
msgstr "Resumes processing from the last successfully completed file."

msgid "cli_recursive_help"
msgstr "Search for PDF files recursively in subdirectories."

msgid "cli_regex_help"
msgstr "Path to the JSON file containing custom regex rules."

msgid "cli_test_help"
msgstr "Test regex rules on the first page of the provided PDF file."

msgid "cli_pages_per_unit_help"
msgstr "Number of pages that make up a single text unit for pattern matching (Default: 1)."

msgid "cli_lang_help"
msgstr "Set the language for user interface and messages (en or pt) (Default: en)."

msgid "err_resume_no_state"
msgstr "No resume state found in the current directory. 'input_dir' must be specified."

msgid "err_input_dir_required"
msgstr "the positional argument 'input_dir' is required unless --resume or --test is used."

msgid "err_regex_required_normal"
msgstr "the '--regex' argument is required to define extraction patterns."

msgid "err_regex_required_resume"
msgstr "the '--regex' argument is required to resume extraction."

msgid "err_ppu_invalid"
msgstr "the '--pages-per-unit' argument must be an integer greater than or equal to 1."

msgid "err_lang_invalid"
msgstr "the '--lang' argument must be 'en' or 'pt'."

msgid "err_dir_not_exist"
msgstr "The input directory '{base_path}' does not exist."

msgid "err_not_a_dir"
msgstr "The input path '{base_path}' is not a directory."

